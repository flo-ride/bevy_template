(
    races: [
        "orc",
        "elf",
        "dwarf",
        "human",
        "wizard",
    ],

    // per-race tuning knobs consumed by the formula above:
    // tolerance divides the raw error before evaluation, mood_bias is added directly
    race_profiles: {
        "orc": (tolerance: 1.5, mood_bias: 0.1),
        "elf": (tolerance: 0.6, mood_bias: 0.0),
        "dwarf": (tolerance: 1.0, mood_bias: -0.05),
        "human": (tolerance: 1.0, mood_bias: 0.0),
        "wizard": (tolerance: 0.8, mood_bias: 0.0),
    },

    // named personas as a map: name -> persona data
    // preferences let a persona react differently to specific recipes
    // (tolerance_bonus stacks on top of the race's base tolerance)
    personas: {
        "bob": (
            race: "orc",
            greetings: [
                "Hello there!",
                "What's brewing, barkeep?",
            ],
            preferences: [
            ],
        ),
        "bobette": (
            race: "orc",
            greetings: [
                "Evening! Surprise me.",
            ],
            preferences: [
            ],
        ),
        "bobo": (
            race: "orc",
            greetings: [
                "Bobo thirsty. Bobo wait.",
            ],
            preferences: [
            ],
        ),
        "elowen": (
            race: "elf",
            greetings: [
                "I expect precision, bartender.",
            ],
            preferences: [
            ],
        ),
        "thrundir": (
            race: "dwarf",
            greetings: [
                "Make it strong or don't bother.",
            ],
            preferences: [
            ],
        ),
    },
)
